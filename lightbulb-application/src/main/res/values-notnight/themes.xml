<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Components" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:statusBarColor">?attr/colorSurface</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="elevationOverlayEnabled">false</item>
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:overScrollMode">ifContentScrolls</item>

        <!-- PRIMARY -->
        <item name="colorPrimary">@color/light_colorPrimary</item>
        <item name="colorOnPrimary">@color/light_colorOnPrimary</item>
        <item name="colorPrimaryContainer">@color/light_colorPrimaryContainer</item>
        <item name="colorOnPrimaryContainer">@color/light_colorOnPrimaryContainer</item>

        <!-- SECONDARY -->
        <item name="colorSecondary">@color/light_colorSecondary</item>
        <item name="colorOnSecondary">@color/light_colorOnSecondary</item>
        <item name="colorSecondaryContainer">@color/light_colorSecondaryContainer</item>
        <item name="colorOnSecondaryContainer">@color/light_colorOnSecondaryContainer</item>

        <!-- TERTIARY -->
        <item name="colorTertiary">@color/light_colorTertiary</item>
        <item name="colorOnTertiary">@color/light_colorOnTertiary</item>
        <item name="colorTertiaryContainer">@color/light_colorTertiaryContainer</item>
        <item name="colorOnTertiaryContainer">@color/light_colorOnTertiaryContainer</item>

        <!-- ERROR -->
        <item name="colorError">@color/light_colorError</item>
        <item name="colorOnError">@color/light_colorOnError</item>
        <item name="colorErrorContainer">@color/light_colorErrorContainer</item>
        <item name="colorOnErrorContainer">@color/light_colorOnErrorContainer</item>

        <!-- SURFACE -->
        <item name="colorSurface">@color/light_colorSurface</item>
        <item name="colorOnSurface">@color/light_colorOnSurface</item>
        <item name="colorSurfaceVariant">@color/light_colorSurfaceVariant</item>
        <item name="colorOnSurfaceVariant">@color/light_colorOnSurfaceVariant</item>

        <!-- BACKGROUND -->
        <item name="android:colorBackground">@color/light_colorBackground</item>
        <item name="colorOnBackground">@color/light_colorOnBackground</item>

        <!-- OUTLINE -->
        <item name="colorOutline">@color/light_colorOutline</item>

        <!-- SURFACE CONTAINERS -->
        <item name="colorSurfaceContainerLowest">@color/light_colorSurfaceContainerLowest</item>
        <item name="colorSurfaceContainerLow">@color/light_colorSurfaceContainerLow</item>
        <item name="colorSurfaceContainer">@color/light_colorSurfaceContainer</item>
        <item name="colorSurfaceContainerHigh">@color/light_colorSurfaceContainerHigh</item>
        <item name="colorSurfaceContainerHighest">@color/light_colorSurfaceContainerHighest</item>
        <item name="colorSurfaceDim">@color/light_colorSurfaceDim</item>
        <item name="colorSurfaceBright">@color/light_colorSurfaceBright</item>

        <!-- INVERSE
        <item name="colorInverseSurface">@color/light_colorSurfaceVariant</item>
        <item name="colorInverseOnSurface">@color/light_colorOnSurface</item>
        <item name="colorInversePrimary">@color/light_colorPrimary</item>-->

        <!-- LEGACY -->
        <item name="colorControlActivated">@color/light_colorPrimary</item>

        <!-- CUSTOM -->
        <item name="colorSuccess">@color/light_colorSuccess</item>
        <item name="colorOnSuccess">@color/light_colorOnSuccess</item>
        <item name="colorWarning">@color/light_colorWarning</item>
        <item name="colorOnWarning">@color/light_colorOnWarning</item>
    </style>
</resources>