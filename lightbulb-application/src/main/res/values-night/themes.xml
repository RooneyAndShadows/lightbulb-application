<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Components" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:statusBarColor">?attr/colorSurface</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="elevationOverlayEnabled">false</item>
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:overScrollMode">ifContentScrolls</item>

        <!-- PRIMARY -->
        <item name="colorPrimary">@color/dark_colorPrimary</item>
        <item name="colorOnPrimary">@color/dark_colorOnPrimary</item>
        <item name="colorPrimaryContainer">@color/dark_colorPrimaryContainer</item>
        <item name="colorOnPrimaryContainer">@color/dark_colorOnPrimaryContainer</item>

        <!-- SECONDARY -->
        <item name="colorSecondary">@color/dark_colorSecondary</item>
        <item name="colorOnSecondary">@color/dark_colorOnSecondary</item>
        <item name="colorSecondaryContainer">@color/dark_colorSecondaryContainer</item>
        <item name="colorOnSecondaryContainer">@color/dark_colorOnSecondaryContainer</item>

        <!-- TERTIARY -->
        <item name="colorTertiary">@color/dark_colorTertiary</item>
        <item name="colorOnTertiary">@color/dark_colorOnTertiary</item>
        <item name="colorTertiaryContainer">@color/dark_colorTertiaryContainer</item>
        <item name="colorOnTertiaryContainer">@color/dark_colorOnTertiaryContainer</item>

        <!-- ERROR -->
        <item name="colorError">@color/dark_colorError</item>
        <item name="colorOnError">@color/dark_colorOnError</item>
        <item name="colorErrorContainer">@color/dark_colorErrorContainer</item>
        <item name="colorOnErrorContainer">@color/dark_colorOnErrorContainer</item>

        <!-- SURFACE -->
        <item name="colorSurface">@color/dark_colorSurface</item>
        <item name="colorOnSurface">@color/dark_colorOnSurface</item>
        <item name="colorSurfaceVariant">@color/dark_colorSurfaceVariant</item>
        <item name="colorOnSurfaceVariant">@color/dark_colorOnSurfaceVariant</item>

        <!-- BACKGROUND -->
        <item name="android:colorBackground">@color/dark_colorBackground</item>
        <item name="colorOnBackground">@color/dark_colorOnBackground</item>

        <!-- OUTLINE -->
        <item name="colorOutline">@color/dark_colorOutline</item>

        <!-- SURFACE CONTAINERS -->
        <item name="colorSurfaceContainerLowest">@color/dark_colorSurfaceContainerLowest</item>
        <item name="colorSurfaceContainerLow">@color/dark_colorSurfaceContainerLow</item>
        <item name="colorSurfaceContainer">@color/dark_colorSurfaceContainer</item>
        <item name="colorSurfaceContainerHigh">@color/dark_colorSurfaceContainerHigh</item>
        <item name="colorSurfaceContainerHighest">@color/dark_colorSurfaceContainerHighest</item>
        <item name="colorSurfaceDim">@color/dark_colorSurfaceDim</item>
        <item name="colorSurfaceBright">@color/dark_colorSurfaceBright</item>

        <!-- INVERSE
        <item name="colorInverseSurface">@color/dark_colorSurfaceVariant</item>
        <item name="colorInverseOnSurface">@color/dark_colorOnSurface</item>
        <item name="colorInversePrimary">@color/dark_colorPrimary</item> -->

        <!-- LEGACY -->
        <item name="colorControlActivated">@color/dark_colorPrimary</item>

        <!-- CUSTOM -->
        <item name="colorSuccess">@color/dark_colorSuccess</item>
        <item name="colorOnSuccess">@color/dark_colorOnSuccess</item>
        <item name="colorWarning">@color/dark_colorWarning</item>
        <item name="colorOnWarning">@color/dark_colorOnWarning</item>
    </style>
</resources>