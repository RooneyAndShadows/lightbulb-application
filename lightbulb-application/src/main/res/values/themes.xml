<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.Components.Dark" parent="Theme.Material3.Dark.NoActionBar">
        <item name="android:statusBarColor">?attr/colorSurface</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="elevationOverlayEnabled">false</item>
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:overScrollMode">ifContentScrolls</item>

        <!-- Primary / Secondary / Tertiary -->
        <item name="colorPrimary">@color/dark_colorPrimary</item>
        <item name="colorOnPrimary">@color/dark_colorOnPrimary</item>
        <item name="colorPrimaryContainer">@color/dark_colorPrimaryContainer</item>
        <item name="colorOnPrimaryContainer">@color/dark_colorOnPrimaryContainer</item>

        <item name="colorSecondary">@color/dark_colorSecondary</item>
        <item name="colorOnSecondary">@color/dark_colorOnSecondary</item>
        <item name="colorSecondaryContainer">@color/dark_colorSecondaryContainer</item>
        <item name="colorOnSecondaryContainer">@color/dark_colorOnSecondaryContainer</item>

        <item name="colorTertiary">@color/dark_colorTertiary</item>
        <item name="colorOnTertiary">@color/dark_colorOnTertiary</item>
        <item name="colorTertiaryContainer">@color/dark_colorTertiaryContainer</item>
        <item name="colorOnTertiaryContainer">@color/dark_colorOnTertiaryContainer</item>

        <!-- Error -->
        <item name="colorError">@color/dark_colorError</item>
        <item name="colorOnError">@color/dark_colorOnError</item>
        <item name="colorErrorContainer">@color/dark_colorErrorContainer</item>
        <item name="colorOnErrorContainer">@color/dark_colorOnErrorContainer</item>

        <!-- Background / Surface -->
        <item name="android:colorBackground">@color/dark_colorBackground</item>
        <item name="colorOnBackground">@color/dark_colorOnBackground</item>
        <item name="colorSurface">@color/dark_colorSurface</item>
        <item name="colorOnSurface">@color/dark_colorOnSurface</item>
        <item name="colorSurfaceVariant">@color/dark_colorSurfaceVariant</item>
        <item name="colorOnSurfaceVariant">@color/dark_colorOnSurfaceVariant</item>
        <item name="colorOutline">@color/dark_colorOutline</item>

        <!-- Legacy / Optional -->
        <item name="colorControlActivated">@color/dark_colorPrimary</item>

        <!-- Custom / Optional feedback -->
        <item name="colorSuccess">@color/dark_colorSuccess</item>
        <item name="colorOnSuccess">@color/dark_colorOnSuccess</item>
        <item name="colorWarning">@color/dark_colorWarning</item>
        <item name="colorOnWarning">@color/dark_colorOnWarning</item>
    </style>

    <style name="Theme.Components.Light" parent="Theme.Material3.Light.NoActionBar">
        <item name="android:statusBarColor">?attr/colorSurface</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="elevationOverlayEnabled">false</item>
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:overScrollMode">ifContentScrolls</item>

        <!-- Primary / Secondary / Tertiary -->
        <item name="colorPrimary">@color/light_colorPrimary</item>
        <item name="colorOnPrimary">@color/light_colorOnPrimary</item>
        <item name="colorPrimaryContainer">@color/light_colorPrimaryContainer</item>
        <item name="colorOnPrimaryContainer">@color/light_colorOnPrimaryContainer</item>

        <item name="colorSecondary">@color/light_colorSecondary</item>
        <item name="colorOnSecondary">@color/light_colorOnSecondary</item>
        <item name="colorSecondaryContainer">@color/light_colorSecondaryContainer</item>
        <item name="colorOnSecondaryContainer">@color/light_colorOnSecondaryContainer</item>

        <item name="colorTertiary">@color/light_colorTertiary</item>
        <item name="colorOnTertiary">@color/light_colorOnTertiary</item>
        <item name="colorTertiaryContainer">@color/light_colorTertiaryContainer</item>
        <item name="colorOnTertiaryContainer">@color/light_colorOnTertiaryContainer</item>

        <!-- Error -->
        <item name="colorError">@color/light_colorError</item>
        <item name="colorOnError">@color/light_colorOnError</item>
        <item name="colorErrorContainer">@color/light_colorErrorContainer</item>
        <item name="colorOnErrorContainer">@color/light_colorOnErrorContainer</item>

        <!-- Background / Surface -->
        <item name="android:colorBackground">@color/light_colorBackground</item>
        <item name="colorOnBackground">@color/light_colorOnBackground</item>
        <item name="colorSurface">@color/light_colorSurface</item>
        <item name="colorOnSurface">@color/light_colorOnSurface</item>
        <item name="colorSurfaceVariant">@color/light_colorSurfaceVariant</item>
        <item name="colorOnSurfaceVariant">@color/light_colorOnSurfaceVariant</item>
        <item name="colorOutline">@color/light_colorOutline</item>

        <!-- Legacy / Optional -->
        <item name="colorControlActivated">@color/light_colorPrimary</item>

        <!-- Custom / Optional feedback -->
        <item name="colorSuccess">@color/light_colorSuccess</item>
        <item name="colorOnSuccess">@color/light_colorOnSuccess</item>
        <item name="colorWarning">@color/light_colorWarning</item>
        <item name="colorOnWarning">@color/light_colorOnWarning</item>
    </style>
</resources>